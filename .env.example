# Copy to Dokploy → Environment (or local .env). Do not commit real secrets.

# CORS: origins allowed by Moqui (comma-separated, no spaces preferred).
# Include the public HTTPS origin of the app.
webapp_allow_origins=https://core-business-ops.sararobotics.org

# Optional JVM heap
JAVA_OPTS=-Xms256m -Xmx1g

{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Evento de Operaciones Especiales",
    "type": "object",
    "properties": {
        "identificacion": {
            "description": "Identificación",
            "type": "object",
            "properties": {
                "version": {
                    "type": "integer",
                    "description": "Versión",
                    "const": 1
                },
                "ambiente": {
                    "type": "string",
                    "description": "Ambiente de destino",
                    "enum": [
                        "00",
                        "01"
                    ]
                },
                "tipoModelo": {
                    "type": "integer",
                    "description": "Modelo de Facturación",
                    "const": 1
                },
                "tipoOperacion": {
                    "type": "integer",
                    "description": "Tipo de Transmisión",
                    "const": 1
                },
                "tipoEvento": {
                    "description": "Tipo de evento",
                    "type": "string",
                    "const": "17"
                },
                "codigoGeneracion": {
                    "type": "string",
                    "description": "Código de Generación",
                    "maxLength": 36,
                    "minLength": 36,
                    "pattern": "^[A-F0-9]{8}-[A-F0-9]{4}-[A-F0-9]{4}-[A-F0-9]{4}-[A-F0-9]{12}$"
                },
                "fecEmi": {
                    "type": "string",
                    "description": "Fecha del Evento",
                    "format": "date"
                },
                "horEmi": {
                    "type": "string",
                    "description": "Hora del Evento",
                    "pattern": "^(0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]?$"
                },
                "tipoMoneda": {
                    "type": "string",
                    "description": "Tipo de Moneda",
                    "const": "USD"
                }
            },
            "additionalProperties": false,
            "required": [
                "version",
                "ambiente",
                "tipoModelo",
                "tipoOperacion",
                "tipoEvento",
                "codigoGeneracion",
                "fecEmi",
                "horEmi",
                "tipoMoneda"
            ]
        },
        "emisor": {
            "type": "object",
            "description": "Información del Emisor",
            "properties": {
                "nit": {
                    "description": "NIT (Emisor)",
                    "type": "string",
                    "maxLength": 14
                },
                "nombre": {
                    "type": "string",
                    "description": "Nombre (Emisor)",
                    "maxLength": 250,
                    "minLength": 1
                }
            },
            "additionalProperties": false,
            "required": [
                "nit",
                "nombre"
            ]
        },
        "cuerpoDocumento": {
            "type": "array",
            "description": "Cuerpo del Documento",
            "items": {
                "type": "object",
                "properties": {
                    "numItem": {
                        "type": "integer",
                        "description": "N° de ítem",
                        "minimum": 1,
                        "maximum": 2000
                    },
                    "codigoGeneracionRef": {
                        "description": "Código de generación del EOE de Referencia",
                        "type": [
                            "string",
                            "null"
                        ],
                        "maxLength": 36,
                        "minLength": 36
                    },
                    "tipoDocumento": {
                        "type": "string",
                        "description": "Tipo de documento"
                    },
                    "numDocumento": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Documento origen",
                        "minLength": 1,
                        "maxLength": 36
                    },
                    "fechaEmision": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Fecha documento origen",
                        "format": "date"
                    },
                    "cantidad": {
                        "type": "integer",
                        "description": "Cantidad",
                        "minimum": 1
                    },
                    "descripcion": {
                        "type": "string",
                        "description": "Descripcion",
                        "minLength": 1,
                        "maxLength": 1500
                    },
                    "docDel": {
                        "description": "Doc. Del",
                        "type": [
                            "string",
                            "null"
                        ],
                        "maxLength": 36
                    },
                    "docAl": {
                        "description": "Doc. Al",
                        "type": [
                            "string",
                            "null"
                        ],
                        "maxLength": 36
                    },
                    "precioUni": {
                        "type": "number",
                        "description": "Precio Unitario",
                        "exclusiveMaximum": 100000000000,
                        "multipleOf": 1e-08,
                        "minimum": 0
                    },
                    "ventaNoSuj": {
                        "type": "number",
                        "description": "Ventas no Sujetas",
                        "exclusiveMaximum": 100000000000,
                        "multipleOf": 1e-08,
                        "minimum": 0
                    },
                    "ventaExenta": {
                        "type": "number",
                        "description": "Ventas Exentas",
                        "exclusiveMaximum": 100000000000,
                        "multipleOf": 1e-08,
                        "minimum": 0
                    },
                    "ventaGravada": {
                        "type": "number",
                        "description": "Ventas Gravadas",
                        "exclusiveMaximum": 100000000000,
                        "multipleOf": 1e-08,
                        "minimum": 0
                    },
                    "tributos": {
                        "description": "Código del Tributo",
                        "type": [
                            "array",
                            "null"
                        ],
                        "items": {
                            "type": "string",
                            "maxLength": 2,
                            "minLength": 2
                        },
                        "minItems": 1,
                        "uniqueItems": true
                    }
                },
                "additionalProperties": false,
                "required": [
                    "numItem",
                    "codigoGeneracionRef",
                    "tipoDocumento",
                    "numDocumento",
                    "fechaEmision",
                    "cantidad",
                    "descripcion",
                    "docDel",
                    "docAl",
                    "precioUni",
                    "ventaNoSuj",
                    "ventaExenta",
                    "ventaGravada",
                    "tributos"
                ]
            },
            "minItems": 1,
            "maxItems": 2000
        },
        "resumen": {
            "type": "object",
            "description": "Resumen",
            "properties": {
                "totalNoSuj": {
                    "type": "number",
                    "description": "Total de Operaciones no Sujetas",
                    "exclusiveMaximum": 100000000000,
                    "multipleOf": 0.01,
                    "minimum": 0
                },
                "totalExenta": {
                    "type": "number",
                    "description": "Total de Operaciones exentas",
                    "exclusiveMaximum": 100000000000,
                    "multipleOf": 0.01,
                    "minimum": 0
                },
                "totalGravada": {
                    "type": "number",
                    "description": "Suma de Operaciones sin Impuestos",
                    "exclusiveMaximum": 100000000000,
                    "multipleOf": 0.01,
                    "minimum": 0
                },
                "subTotal": {
                    "type": "number",
                    "description": "Sub-total",
                    "exclusiveMaximum": 100000000000,
                    "multipleOf": 0.01,
                    "minimum": 0
                },
                "tributos": {
                    "type": [
                        "array",
                        "null"
                    ],
                    "uniqueItems": true,
                    "description": "Resumen Código de Tributo",
                    "items": {
                        "type": "object",
                        "properties": {
                            "codigo": {
                                "description": "Resumen Código de Tributo",
                                "type": "string",
                                "minLength": 2,
                                "maxLength": 2
                            },
                            "descripcion": {
                                "description": "Nombre del Tributo",
                                "type": "string",
                                "minLength": 1,
                                "maxLength": 300
                            },
                            "valor": {
                                "description": "Valor del Tributo",
                                "type": "number",
                                "exclusiveMaximum": 100000000000,
                                "multipleOf": 0.01
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "codigo",
                            "descripcion",
                            "valor"
                        ]
                    }
                },
                "total": {
                    "type": "number",
                    "description": "Total",
                    "exclusiveMaximum": 100000000000,
                    "multipleOf": 0.01,
                    "minimum": 0
                },
                "totalLetras": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Valor en Letras",
                    "minLength": 8,
                    "maxLength": 200
                }
            },
            "additionalProperties": false,
            "required": [
                "totalNoSuj",
                "totalExenta",
                "totalGravada",
                "subTotal",
                "tributos",
                "total",
                "totalLetras"
            ]
        },
        "apendice": {
            "description": "Apéndice",
            "type": [
                "array",
                "null"
            ],
            "items": {
                "type": "object",
                "properties": {
                    "campo": {
                        "type": "string",
                        "description": "Nombre del campo",
                        "maxLength": 25
                    },
                    "etiqueta": {
                        "type": "string",
                        "description": "Descripción",
                        "maxLength": 50
                    },
                    "valor": {
                        "type": "string",
                        "description": "Valor/Dato",
                        "maxLength": 150
                    }
                },
                "additionalProperties": false,
                "required": [
                    "campo",
                    "etiqueta",
                    "valor"
                ]
            },
            "minItems": 1,
            "maxItems": 10
        }
    },
    "additionalProperties": false,
    "required": [
        "identificacion",
        "emisor",
        "cuerpoDocumento",
        "resumen",
        "apendice"
    ]
}
{
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "Evento de Contingencia de Documento Tributario Electronico",
    "type": "object",
    "properties": {
        "identificacion": {
            "description": "Identificación",
            "type": "object",
            "properties": {
                "version": {
                    "type": "integer",
                    "description": "Versión del esquema del evento",
                    "const": 4
                },
                "ambiente": {
                    "type": "string",
                    "description": "Ambiente de destino",
                    "enum": [
                        "00",
                        "01"
                    ]
                },
                "codigoGeneracion": {
                    "description": "Código de Generación Evento Contingencia.",
                    "pattern": "^[A-F0-9]{8}-[A-F0-9]{4}-[A-F0-9]{4}-[A-F0-9]{4}-[A-F0-9]{12}$",
                    "type": "string",
                    "maxLength": 36,
                    "minLength": 36
                },
                "fTransmision": {
                    "type": "string",
                    "description": "Fecha del evento de contingencia",
                    "format": "date"
                },
                "hTransmision": {
                    "type": "string",
                    "description": "Hora del evento contigencia",
                    "pattern": "^(0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]?$"
                }
            },
            "additionalProperties": false,
            "required": [
                "version",
                "ambiente",
                "codigoGeneracion",
                "fTransmision",
                "hTransmision"
            ]
        },
        "emisor": {
            "description": "Informacion del emisor",
            "type": "object",
            "properties": {
                "nit": {
                    "description": "NIT (Emisor)",
                    "type": "string"
                },
                "nombre": {
                    "description": "Nombre (Emisor)",
                    "type": "string",
                    "maxLength": 250,
                    "minLength": 1
                },
                "nombreResponsable": {
                    "description": "NOMBRE DEL RESPONSABLE DEL ESTABLECIMIENTO.",
                    "type": "string",
                    "maxLength": 100,
                    "minLength": 1
                },
                "tipoDocResponsable": {
                    "type": "string",
                    "description": "Tipo de documento de identificación"
                },
                "numeroDocResponsable": {
                    "description": "NUMERO DE DOCUMENTO DE IDENTIFICACION",
                    "type": "string",
                    "maxLength": 25,
                    "minLength": 1
                },
                "tipoEstablecimiento": {
                    "description": "TIPO DE ESTABLECIMIENTO (EMISOR)",
                    "type": "string"
                },
                "codEstableMH": {
                    "description": "Código del establecimiento asignado por el MH",
                    "type": [
                        "string",
                        "null"
                    ],
                    "maxLength": 4,
                    "minLength": 4
                },
                "codPuntoVentaMH": {
                    "description": "Código del Punto de Venta (Emisor) Asignado por el MH",
                    "type": [
                        "string",
                        "null"
                    ],
                    "minLength": 4,
                    "maxLength": 4
                },
                "telefono": {
                    "type": "string",
                    "description": "Telefono (Emisor)",
                    "minLength": 8,
                    "maxLength": 30
                },
                "correo": {
                    "type": "string",
                    "description": "Correo electronico del emisor",
                    "maxLength": 100,
                    "minLength": 1
                }
            },
            "additionalProperties": false,
            "required": [
                "nit",
                "nombre",
                "nombreResponsable",
                "tipoDocResponsable",
                "numeroDocResponsable",
                "tipoEstablecimiento",
                "codEstableMH",
                "codPuntoVentaMH",
                "telefono",
                "correo"
            ]
        },
        "detalleDTE": {
            "description": "Detalle de los documentos que se enviaran en contingencia.",
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "noItem": {
                        "description": "Numero correlativo.",
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 1000
                    },
                    "tipoDoc": {
                        "description": "Tipo de Documento en contingencia",
                        "type": "string"
                    },
                    "codigoGeneracion": {
                        "description": "Codigo de generacion del documento",
                        "type": "string"
                    }
                },
                "additionalProperties": false,
                "required": [
                    "noItem",
                    "tipoDoc",
                    "codigoGeneracion"
                ]
            },
            "minItems": 1,
            "maxItems": 1000
        },
        "motivo": {
            "description": "Motivo de la contingenia.",
            "type": "object",
            "properties": {
                "fInicio": {
                    "description": "Fecha inicio de la contingencia",
                    "type": "string",
                    "format": "date"
                },
                "fFin": {
                    "description": "Fecha fin de contingencia",
                    "type": "string",
                    "format": "date"
                },
                "hInicio": {
                    "description": "Hora inicio de contingencia.",
                    "type": "string"
                },
                "hFin": {
                    "description": "Hora fin de la contingencia.",
                    "type": "string"
                },
                "tipoContingencia": {
                    "description": "Tipo de contingencia.",
                    "type": "integer"
                },
                "motivoContingencia": {
                    "description": "Descripcion del motivo de la contingencia.",
                    "type": [
                        "string",
                        "null"
                    ],
                    "maxLength": 500
                }
            },
            "additionalProperties": false,
            "required": [
                "fInicio",
                "fFin",
                "hInicio",
                "hFin",
                "tipoContingencia",
                "motivoContingencia"
            ]
        }
    },
    "additionalProperties": false,
    "required": [
        "identificacion",
        "emisor",
        "detalleDTE",
        "motivo"
    ]
}
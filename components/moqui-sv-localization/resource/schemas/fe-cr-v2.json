{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Comprobante de Retención Electrónico",
    "type": "object",
    "properties": {
        "identificacion": {
            "description": "Identificación",
            "type": "object",
            "properties": {
                "version": {
                    "type": "integer",
                    "description": "Versión",
                    "const": 2
                },
                "ambiente": {
                    "type": "string",
                    "description": "Ambiente de destino",
                    "minLength": 2,
                    "maxLength": 2,
                    "enum": [
                        "00",
                        "01"
                    ]
                },
                "tipoDte": {
                    "type": "string",
                    "description": "Tipo de Documento",
                    "const": "07"
                },
                "numeroControl": {
                    "type": "string",
                    "description": "Número de Control",
                    "minLength": 31,
                    "maxLength": 31,
                    "pattern": "^DTE-07-(M|B|S|P)([0-9]{3})(P)([0-9]{3})-[0-9]{15}$"
                },
                "codigoGeneracion": {
                    "type": "string",
                    "description": "Código de Generación",
                    "minLength": 36,
                    "maxLength": 36,
                    "pattern": "^[A-F0-9]{8}-[A-F0-9]{4}-[A-F0-9]{4}-[A-F0-9]{4}-[A-F0-9]{12}$"
                },
                "tipoModelo": {
                    "type": "number",
                    "description": "Modelo de Facturación"
                },
                "tipoOperacion": {
                    "type": "integer",
                    "description": "Tipo de Transmisión"
                },
                "tipoContingencia": {
                    "type": [
                        "integer",
                        "null"
                    ],
                    "description": "Tipo de Contingencia"
                },
                "motivoContin": {
                    "description": "Motivo de Contingencia",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "fecEmi": {
                    "type": "string",
                    "description": "Fecha de Generación",
                    "format": "date"
                },
                "horEmi": {
                    "type": "string",
                    "description": "Hora de Generación",
                    "pattern": "^(0[0-9]|1[0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]?$"
                },
                "tipoMoneda": {
                    "type": "string",
                    "description": "Tipo de Moneda",
                    "enum": [
                        "USD"
                    ]
                },
                "fusion": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Fusiónes y otros"
                }
            },
            "additionalProperties": false,
            "required": [
                "version",
                "ambiente",
                "tipoDte",
                "numeroControl",
                "codigoGeneracion",
                "tipoModelo",
                "tipoOperacion",
                "tipoContingencia",
                "motivoContin",
                "fecEmi",
                "horEmi",
                "tipoMoneda"
            ]
        },
        "emisor": {
            "type": "object",
            "description": "Emisor",
            "properties": {
                "nit": {
                    "description": "NIT (Emisor)",
                    "type": "string"
                },
                "nrc": {
                    "description": "NRC (Emisor)",
                    "type": [
                        "string",
                        "null"
                    ],
                    "minLength": 2,
                    "maxLength": 8
                },
                "nombre": {
                    "type": "string",
                    "description": "Nombre (Emisor)",
                    "minLength": 1,
                    "maxLength": 250
                },
                "codActividad": {
                    "type": "string",
                    "description": "Código de Actividad Económica (Emisor)",
                    "maxLength": 6,
                    "minLength": 5
                },
                "descActividad": {
                    "type": "string",
                    "description": "Actividad Económica (Emisor)",
                    "maxLength": 150,
                    "minLength": 5
                },
                "nombreComercial": {
                    "description": "Nombre Comercial (Emisor)",
                    "type": [
                        "string",
                        "null"
                    ],
                    "minLength": 1,
                    "maxLength": 150
                },
                "direccion": {
                    "type": "object",
                    "description": "Dirección (Emisor)",
                    "properties": {
                        "departamento": {
                            "type": "string",
                            "description": "Dirección Departamento (Emisor)"
                        },
                        "municipio": {
                            "type": "string",
                            "description": "Dirección Municipio (Emisor)"
                        },
                        "distrito": {
                            "type": "string",
                            "description": "Dirección Distrito (Emisor)"
                        },
                        "complemento": {
                            "type": "string",
                            "description": "Dirección complemento (Emisor)",
                            "maxLength": 200,
                            "minLength": 1
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "departamento",
                        "municipio",
                        "distrito",
                        "complemento"
                    ]
                },
                "codEstable": {
                    "description": "Código del establecimiento asignado por el contribuyente",
                    "type": [
                        "string",
                        "null"
                    ],
                    "maxLength": 4,
                    "minLength": 4
                },
                "codPuntoVenta": {
                    "description": "Código del Punto de Venta (Emisor) asignado por el contribuyente",
                    "type": [
                        "string",
                        "null"
                    ],
                    "maxLength": 15,
                    "minLength": 1
                },
                "telefono": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Teléfono (Emisor)",
                    "minLength": 8,
                    "maxLength": 30
                },
                "correo": {
                    "type": "string",
                    "description": "Correo electrónico (Emisor)",
                    "maxLength": 100,
                    "minLength": 6
                }
            },
            "additionalProperties": false,
            "required": [
                "nit",
                "nrc",
                "nombre",
                "codActividad",
                "descActividad",
                "nombreComercial",
                "direccion",
                "codEstable",
                "codPuntoVenta",
                "telefono",
                "correo"
            ]
        },
        "receptor": {
            "type": "object",
            "description": "Receptor",
            "properties": {
                "tipoDocumento": {
                    "type": "string",
                    "description": "Tipo de documento de identificación (Receptor)"
                },
                "numDocumento": {
                    "type": "string",
                    "description": "Número de documento de Identificación (Receptor)",
                    "minLength": 1,
                    "maxLength": 20
                },
                "nrc": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "NRC (Receptor)",
                    "minLength": 2,
                    "maxLength": 8
                },
                "nombre": {
                    "type": "string",
                    "description": "Nombre (Receptor)",
                    "minLength": 1,
                    "maxLength": 250
                },
                "codActividad": {
                    "type": "string",
                    "description": "Código de Actividad Económica (Receptor)"
                },
                "descActividad": {
                    "type": "string",
                    "description": "Actividad Económica (Receptor)",
                    "minLength": 5,
                    "maxLength": 150
                },
                "nombreComercial": {
                    "description": "Nombre Comercial (Receptor)",
                    "type": [
                        "string",
                        "null"
                    ],
                    "maxLength": 150,
                    "minLength": 1
                },
                "direccion": {
                    "type": "object",
                    "description": "Dirección (Receptor)",
                    "properties": {
                        "departamento": {
                            "type": "string",
                            "description": "Dirección: Departamento (Receptor)"
                        },
                        "municipio": {
                            "type": "string",
                            "description": "Dirección: Municipio (Receptor)"
                        },
                        "distrito": {
                            "type": "string",
                            "description": "Dirección: Distrito (Receptor)"
                        },
                        "complemento": {
                            "type": "string",
                            "description": "Dirección: complemento (Receptor)",
                            "maxLength": 200,
                            "minLength": 1
                        }
                    },
                    "additionalProperties": false,
                    "required": [
                        "departamento",
                        "municipio",
                        "distrito",
                        "complemento"
                    ]
                },
                "telefono": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Teléfono (Receptor)",
                    "minLength": 8,
                    "maxLength": 30
                },
                "correo": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Correo electrónico (Receptor)",
                    "minLength": 6,
                    "maxLength": 100
                }
            },
            "additionalProperties": false,
            "required": [
                "tipoDocumento",
                "numDocumento",
                "codActividad",
                "descActividad",
                "nrc",
                "nombre",
                "nombreComercial",
                "direccion",
                "telefono",
                "correo"
            ]
        },
        "cuerpoDocumento": {
            "type": "array",
            "description": "Cuerpo del Documento",
            "items": {
                "type": "object",
                "properties": {
                    "numItem": {
                        "type": "integer",
                        "description": "N° de ítem",
                        "minimum": 1,
                        "maximum": 500
                    },
                    "tipoDte": {
                        "type": [
                            "null",
                            "string"
                        ],
                        "description": "Tipo de Documento Relacionado"
                    },
                    "tipoGeneracion": {
                        "type": [
                            "null",
                            "integer"
                        ],
                        "description": "Tipo de generación del documento relacionado"
                    },
                    "numDocumento": {
                        "description": "Número de documento relacionado",
                        "type": [
                            "null",
                            "string"
                        ]
                    },
                    "fechaEmision": {
                        "description": "Fecha de generación del documento relacionado",
                        "type": [
                            "null",
                            "string"
                        ],
                        "format": "date"
                    },
                    "montoSujetoGrav": {
                        "type": "number",
                        "description": "Monto Sujeto a retención",
                        "exclusiveMinimum": 0,
                        "exclusiveMaximum": 100000000000,
                        "multipleOf": 0.01
                    },
                    "codigoRetencionMH": {
                        "type": "string",
                        "description": "Código retención MH"
                    },
                    "ivaRetenido": {
                        "type": "number",
                        "description": "IVA Retenido",
                        "exclusiveMinimum": 0,
                        "exclusiveMaximum": 100000000000,
                        "multipleOf": 0.01
                    },
                    "descripcion": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Descripción",
                        "minLength": 1,
                        "maxLength": 1500
                    }
                },
                "additionalProperties": false,
                "required": [
                    "numItem",
                    "tipoDte",
                    "tipoGeneracion",
                    "numDocumento",
                    "fechaEmision",
                    "montoSujetoGrav",
                    "codigoRetencionMH",
                    "ivaRetenido",
                    "descripcion"
                ]
            },
            "minItems": 1,
            "maxItems": 500
        },
        "resumen": {
            "type": "object",
            "description": "Resumen",
            "properties": {
                "totalSujetoRetencion": {
                    "type": "number",
                    "description": "Total Monto Sujeto a retención",
                    "exclusiveMinimum": 0,
                    "exclusiveMaximum": 100000000000,
                    "multipleOf": 0.01
                },
                "totalIva": {
                    "type": "number",
                    "description": "IVA 13%",
                    "minimum": 0,
                    "exclusiveMaximum": 100000000000,
                    "multipleOf": 0.01
                },
                "totalIvaRetenido": {
                    "type": "number",
                    "description": "Total IVA Retenido",
                    "exclusiveMinimum": 0,
                    "exclusiveMaximum": 100000000000,
                    "multipleOf": 0.01
                },
                "totalLetras": {
                    "type": [
                        "null",
                        "string"
                    ],
                    "description": "Valor en letras",
                    "minLength": 1,
                    "maxLength": 200
                },
                "observaciones": {
                    "type": [
                        "string",
                        "null"
                    ],
                    "description": "Observaciones",
                    "minLength": 1,
                    "maxLength": 3000
                }
            },
            "additionalProperties": false,
            "required": [
                "totalSujetoRetencion",
                "totalIva",
                "totalIvaRetenido",
                "totalLetras",
                "observaciones"
            ]
        },
        "apendice": {
            "description": "Apéndice",
            "type": [
                "array",
                "null"
            ],
            "items": {
                "type": "object",
                "properties": {
                    "campo": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Nombre del campo",
                        "minLength": 1,
                        "maxLength": 25
                    },
                    "etiqueta": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Descripción",
                        "minLength": 1,
                        "maxLength": 50
                    },
                    "valor": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "description": "Valor/Dato",
                        "minLength": 1,
                        "maxLength": 150
                    }
                },
                "additionalProperties": false,
                "required": [
                    "campo",
                    "etiqueta",
                    "valor"
                ]
            },
            "minItems": 1,
            "maxItems": 10
        }
    },
    "additionalProperties": false,
    "required": [
        "identificacion",
        "emisor",
        "receptor",
        "cuerpoDocumento",
        "resumen",
        "apendice"
    ]
}
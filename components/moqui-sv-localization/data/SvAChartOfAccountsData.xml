<?xml version="1.0" encoding="UTF-8"?>
<!--
    Plan de cuentas El Salvador (catálogo base mínimo para nómina, DTE y cierre).

    Estructura por dígito:
      1xxx Activo (DEBIT)
      2xxx Pasivo (CREDIT)
      3xxx Patrimonio (CREDIT)
      4xxx Ingresos (CREDIT - REVENUE)
      5xxx Costos (DEBIT - COST_OF_SALES)
      6xxx Gastos (DEBIT - EXPENSE)

    Los IDs siguen el patrón SV_<código> para facilitar la lectura.
    accountCode contiene el código SV (4-7 dígitos) tal como se mostrara en
    reportes y libros oficiales.

    Esta seed es independiente de organización (las cuentas son globales).
    Cada organización emisora (OrgInternal) debe asociarse vía
    GlAccountOrganization tras cargar este seed — ver post-instalación en
    docs/CONTABILIDAD_SV.md.
-->
<entity-facade-xml type="seed">

    <!-- ============================================================== -->
    <!-- ACTIVO (1xxx)                                                  -->
    <!-- ============================================================== -->

    <mantle.ledger.account.GlAccount glAccountId="SV_1000"
            accountCode="1000" accountName="ACTIVO"
            glAccountClassEnumId="ASSET" disallowPosting="Y"/>


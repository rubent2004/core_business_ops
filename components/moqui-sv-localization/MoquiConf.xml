<?xml version="1.0" encoding="UTF-8" ?>
<moqui-conf xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/moqui-conf-3.xsd">

    <default-property name="default_locale" value="es_SV"/>
    <default-property name="default_time_zone" value="America/El_Salvador"/>

    <default-property name="sv.dte.firmador.url" value="http://localhost:8113"/>
    <default-property name="sv.dte.mh.ambiente.default" value="00"/>
    <default-property name="sv.dte.mh.mock.enabled" value="true"/>
    <default-property name="sv.dte.sign.mock.enabled" value="false"/>
    <default-property name="sv.dte.verification.public.url" value="https://admin.factura.gob.sv/consultaPublica"/>
    <default-property name="sv.dte.test.local" value="true"/>
    <default-property name="sv.dte.local.auth.url" value="http://localhost:8080/rest/s1/sv-dte-sim/seguridad/auth"/>
    <default-property name="sv.dte.local.recepcion.url" value="http://localhost:8080/rest/s1/sv-dte-sim/fesv/recepciondte"/>
    <default-property name="sv.dte.local.anulacion.url" value="http://localhost:8080/rest/s1/sv-dte-sim/fesv/anulardte"/>
    <default-property name="sv.dte.local.contingencia.url" value="http://localhost:8080/rest/s1/sv-dte-sim/fesv/contingencia"/>
    <default-property name="sv.dte.local.consulta.url" value="http://localhost:8080/rest/s1/sv-dte-sim/fesv/recepcion/consultadte"/>
    <default-property name="sv.dte.local.demo.user" value="demo"/>
    <default-property name="sv.dte.local.demo.password" value="hacienda"/>
    <default-property name="sv.dte.mh.test.auth.url" value="https://apitest.dtes.mh.gob.sv/seguridad/auth"/>
    <default-property name="sv.dte.mh.test.recepcion.url" value="https://apitest.dtes.mh.gob.sv/fesv/recepciondte"/>
    <default-property name="sv.dte.mh.test.anulacion.url" value="https://apitest.dtes.mh.gob.sv/fesv/anulardte"/>
    <default-property name="sv.dte.mh.test.contingencia.url" value="https://apitest.dtes.mh.gob.sv/fesv/contingencia"/>
    <default-property name="sv.dte.mh.test.consulta.url" value="https://apitest.dtes.mh.gob.sv/fesv/recepcion/consultadte"/>
    <default-property name="sv.dte.demo.cert.password" value="hacienda"/>
    <default-property name="sv.dte.demo.mh.password" value="hacienda"/>
    <default-property name="sv.dte.numero_control.establishment" value="M001P001"/>
    <default-property name="sv.dte.resilience.enabled" value="true"/>
    <default-property name="sv.dte.resilience.failure.threshold" value="3"/>
    <default-property name="sv.dte.resilience.degraded.threshold" value="1"/>
    <default-property name="sv.dte.resilience.health.cooldown.seconds" value="60"/>
    <default-property name="sv.dte.resilience.retry.max.attempts" value="3"/>
    <default-property name="sv.dte.resilience.retry.base.minutes" value="1"/>
    <default-property name="sv.dte.resilience.connect.timeout.ms" value="5000"/>
    <default-property name="sv.dte.resilience.read.timeout.ms" value="8000"/>
    <default-property name="sv.dte.contingency.legal.hours" value="24"/>
    <default-property name="sv.dte.seca.auto_emit.enabled" value="false"/>
    <default-property name="sv.dte.seca.auto_post.enabled" value="false"/>

    <screen-facade>
        <!-- Montar screens SARA bajo webroot directamente -->
        <screen location="component://webroot/screen/webroot.xml">
            <subscreens-item name="SvDashboard" menu-title="SARA Dashboard" menu-index="1"
                    location="component://moqui-sv-localization/screen/SvDashboard.xml"/>
            <subscreens-item name="SvLocalization" menu-title="Fiscal SV" menu-index="8"
                    location="component://moqui-sv-localization/screen/SvLocalization.xml"/>
            <subscreens-item name="SvAdmin" menu-title="Admin SV" menu-index="9"
                    location="component://moqui-sv-localization/screen/SvAdmin.xml"/>
        </screen>

        <!-- Tabs fiscales en pantallas existentes -->
        <screen location="component://SimpleScreens/screen/SimpleScreens/Party.xml">
            <subscreens-item name="SvFiscal" menu-title="Datos Fiscales" menu-index="2"
                    location="component://moqui-sv-localization/screen/SvLocalization/PartyTabs/SvFiscal.xml"/>
        </screen>
        <screen location="component://SimpleScreens/screen/SimpleScreens/Customer.xml">
            <subscreens-item name="FindCustomer" menu-title="Buscar" menu-index="1"
                    location="component://moqui-sv-localization/screen/SvLocalization/FindScreens/FindCustomerSv.xml"/>
            <subscreens-item name="EditCustomer" menu-title="Cliente" menu-index="2"
                    location="component://moqui-sv-localization/screen/SvLocalization/EditCustomerSv.xml"/>
        </screen>
        <screen location="component://SimpleScreens/screen/SimpleScreens/Supplier.xml">
            <subscreens-item name="FindSupplier" menu-title="Buscar" menu-index="1"
                    location="component://moqui-sv-localization/screen/SvLocalization/FindScreens/FindSupplierSv.xml"/>
            <subscreens-item name="EditSupplier" menu-title="Proveedor" menu-index="2"
                    location="component://moqui-sv-localization/screen/SvLocalization/EditSupplierSv.xml"/>
        </screen>
        <screen location="component://SimpleScreens/screen/SimpleScreens/Accounting/Invoice.xml">
            <subscreens-item name="Dte" menu-title="Factura Electrónica" menu-index="2"
                    location="component://moqui-sv-localization/screen/SvLocalization/InvoiceTabs/Dte.xml"/>
        </screen>
        <screen location="component://SimpleScreens/screen/SimpleScreens/Manufacturing/Run.xml">
            <subscreens-item name="FindRun" menu-title="Buscar" menu-index="1"
                    location="component://moqui-sv-localization/screen/SvLocalization/ManufacturingScreens/FindRunSv.xml"/>
            <subscreens-item name="EditRun" menu-title="Orden" menu-index="2"
                    location="component://moqui-sv-localization/screen/SvLocalization/ManufacturingScreens/EditRunSv.xml"/>
            <subscreens-item name="RunCostSheet" menu-title="Hoja de Costeo" menu-index="6"
                    location="component://moqui-sv-localization/screen/SvLocalization/ManufacturingScreens/RunCostSheet.xml"/>
        </screen>
    </screen-facade>

</moqui-conf>

<?xml version="1.0" encoding="UTF-8"?>
<entities xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/entity-definition-3.xsd">

    <view-entity entity-name="SvPartyFiscalSearch" package="sv.localization.search">
        <member-entity entity-alias="PTY" entity-name="mantle.party.Party"/>
        <member-entity entity-alias="ORG" entity-name="mantle.party.Organization" join-from-alias="PTY" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="PER" entity-name="mantle.party.Person" join-from-alias="PTY" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="FP" entity-name="sv.localization.party.SvFiscalProfile" join-from-alias="PTY" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>

        <alias entity-alias="PTY" name="partyId"/>
        <alias entity-alias="PTY" name="pseudoId"/>
        <alias entity-alias="PTY" name="partyTypeEnumId"/>
        <alias entity-alias="PTY" name="disabled"/>
        <alias entity-alias="ORG" name="organizationName"/>
        <alias entity-alias="PER" name="firstName"/>
        <alias entity-alias="PER" name="lastName"/>
        <alias entity-alias="PER" name="dui"/>
        <alias entity-alias="FP" name="tipoContribuyenteEnumId"/>
        <alias entity-alias="FP" name="nombreComercial"/>
        <alias entity-alias="FP" name="nrc"/>
        <alias entity-alias="FP" name="actividadEconomicaId"/>
    </view-entity>

    <view-entity entity-name="SvInvoiceDteSearch" package="sv.localization.search">
        <member-entity entity-alias="INV" entity-name="mantle.account.invoice.Invoice"/>
        <member-entity entity-alias="TPTY" entity-name="mantle.party.Party" join-from-alias="INV" join-optional="true">
            <key-map field-name="toPartyId" related="partyId"/>
        </member-entity>
        <member-entity entity-alias="TORG" entity-name="mantle.party.Organization" join-from-alias="TPTY" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="TPER" entity-name="mantle.party.Person" join-from-alias="TPTY" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="DTE" entity-name="sv.localization.dte.DteEmision" join-from-alias="INV" join-optional="true">
            <key-map field-name="invoiceId"/>
        </member-entity>

        <alias entity-alias="INV" name="invoiceId"/>
        <alias entity-alias="INV" name="invoiceTypeEnumId"/>
        <alias entity-alias="INV" name="fromPartyId"/>
        <alias entity-alias="INV" name="toPartyId"/>
        <alias entity-alias="INV" name="statusId"/>
        <alias entity-alias="INV" name="invoiceDate"/>
        <alias entity-alias="INV" name="currencyUomId"/>
        <alias entity-alias="INV" name="invoiceTotal"/>
        <alias entity-alias="INV" name="tipoDteCode"/>
        <alias entity-alias="INV" name="condicionOperacionEnumId"/>
        <alias entity-alias="INV" name="formaPagoEnumId"/>
        <alias entity-alias="TPTY" name="toPartyPseudoId" field="pseudoId"/>
        <alias name="toPartyName" function="concat_ws" type="text-medium"><complex-alias operator=",">
            <complex-alias expression="' '"/>
            <complex-alias-field entity-alias="TORG" field="organizationName"/>
            <complex-alias-field entity-alias="TPER" field="firstName"/>
            <complex-alias-field entity-alias="TPER" field="lastName"/>
        </complex-alias></alias>
        <alias entity-alias="DTE" name="dteStatusId" field="statusId"/>
        <alias entity-alias="DTE" name="dteEmisionId"/>
        <alias entity-alias="DTE" name="numeroControl"/>
        <alias entity-alias="DTE" name="codigoGeneracion"/>
        <alias entity-alias="DTE" name="selloRecepcion"/>
        <alias entity-alias="DTE" name="fechaGeneracion"/>
    </view-entity>

    <view-entity entity-name="SvOrderFiscalSearch" package="sv.localization.search">
        <member-entity entity-alias="OPRT" entity-name="mantle.order.OrderPart"/>
        <member-entity entity-alias="ORHD" entity-name="mantle.order.OrderHeader" join-from-alias="OPRT">
            <key-map field-name="orderId"/>
        </member-entity>
        <member-entity entity-alias="CPTY" entity-name="mantle.party.Party" join-from-alias="OPRT" join-optional="true">
            <key-map field-name="customerPartyId" related="partyId"/>
        </member-entity>
        <member-entity entity-alias="CORG" entity-name="mantle.party.Organization" join-from-alias="CPTY" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="CPER" entity-name="mantle.party.Person" join-from-alias="CPTY" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="CFP" entity-name="sv.localization.party.SvFiscalProfile" join-from-alias="CPTY" join-optional="true">
            <key-map field-name="partyId"/>
        </member-entity>
        <member-entity entity-alias="CNIT" entity-name="mantle.party.PartyIdentification" join-from-alias="CPTY" join-optional="true">
            <key-map field-name="partyId"/>
            <entity-condition><econdition field-name="partyIdTypeEnumId" value="PitNit"/></entity-condition>
        </member-entity>
        <member-entity entity-alias="CDUI" entity-name="mantle.party.PartyIdentification" join-from-alias="CPTY" join-optional="true">
            <key-map field-name="partyId"/>
            <entity-condition><econdition field-name="partyIdTypeEnumId" value="PitDui"/></entity-condition>
        </member-entity>
        <member-entity entity-alias="CNRC" entity-name="mantle.party.PartyIdentification" join-from-alias="CPTY" join-optional="true">
            <key-map field-name="partyId"/>
            <entity-condition><econdition field-name="partyIdTypeEnumId" value="PitNrc"/></entity-condition>
        </member-entity>

        <alias entity-alias="OPRT" name="orderId"/>
        <alias entity-alias="OPRT" name="orderPartSeqId"/>
        <alias entity-alias="ORHD" name="entryDate"/>
        <alias entity-alias="ORHD" name="orderStatusId" field="statusId"/>
        <alias entity-alias="ORHD" name="currencyUomId"/>
        <alias entity-alias="OPRT" name="partStatusId" field="statusId"/>
        <alias entity-alias="OPRT" name="vendorPartyId"/>
        <alias entity-alias="OPRT" name="customerPartyId"/>
        <alias entity-alias="OPRT" name="partTotal"/>
        <alias entity-alias="OPRT" name="svTipoDteCode"/>
        <alias entity-alias="OPRT" name="svCondicionOperacionEnumId"/>
        <alias entity-alias="OPRT" name="svFormaPagoEnumId"/>
        <alias entity-alias="CPTY" name="customerPseudoId" field="pseudoId"/>
        <alias entity-alias="CORG" name="organizationName"/>
        <alias entity-alias="CPER" name="firstName"/>
        <alias entity-alias="CPER" name="lastName"/>
        <alias name="customerName" function="concat_ws" type="text-medium"><complex-alias operator=",">
            <complex-alias expression="' '"/>
            <complex-alias-field entity-alias="CORG" field="organizationName"/>
            <complex-alias-field entity-alias="CPER" field="firstName"/>
            <complex-alias-field entity-alias="CPER" field="lastName"/>
        </complex-alias></alias>
        <alias entity-alias="CNIT" name="nit" field="idValue"/>
        <alias entity-alias="CDUI" name="dui" field="idValue"/>
        <alias entity-alias="CNRC" name="nrc" field="idValue"/>
        <alias entity-alias="CFP" name="tipoContribuyenteEnumId"/>
        <alias entity-alias="CFP" name="actividadEconomicaId"/>
    </view-entity>

</entities>

<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Proveedor" default-menu-index="1">

    <parameter name="partyId" required="true"/>

    <!-- Standard transitions from EditSupplier -->
    <transition name="findOrder"><default-response url="../../Order/FindOrder"/></transition>
    <transition name="updateParty"><service-call name="mantle.party.PartyServices.update#PartyDetail"/>
        <default-response url="."/></transition>

    <transition name="createPartyRole"><service-call name="create#mantle.party.PartyRole"/>
        <default-response url="."/></transition>
    <transition name="deletePartyRole"><service-call name="delete#mantle.party.PartyRole"/>
        <default-response url="."/></transition>

    <transition name="updatePaymentMethodInfo"><default-response url="UpdatePaymentMethodInfo"/></transition>
    <transition name="removePaymentMethod"><service-call name="mantle.account.PaymentMethodServices.delete#PaymentMethod"/>
        <default-response url="."/></transition>
    <transition name="findFinancialAccount"><default-response url="//${appRoot}/Accounting/FinancialAccount/FindFinancialAccount"/></transition>
    <transition name="editFinancialAccount"><default-response url="//${appRoot}/Accounting/FinancialAccount/EditFinancialAccount"/></transition>

    <transition name="storePartyContactMech"><service-call name="mantle.party.ContactServices.store#PartyContactMech"/>
        <default-response url="."/></transition>
    <transition name="removeContactInfo"><service-call name="mantle.party.ContactServices.delete#PartyContactMech"/>
        <default-response url="."/></transition>
    <transition name="updateContactMechMutable"><service-call name="mantle.party.ContactServices.update#ContactMechMutable"/>
        <default-response url="."/></transition>

    <transition name="createContactMechOther"><service-call name="mantle.party.ContactServices.create#ContactMechOther"/>
        <default-response url="."/></transition>
    <transition name="updatePartyContactOther"><service-call name="mantle.party.ContactServices.update#PartyContactOther"/>
        <default-response url="."/></transition>
    <transition-include name="getContactMechPurposesByType" location="component://SimpleScreens/template/party/PartyForms.xml"/>

    <transition name="createPartyNote"><service-call name="create#mantle.party.PartyNote"/>
        <default-response url="."/></transition>
    <transition name="updatePartyNote"><service-call name="update#mantle.party.PartyNote"/>
        <default-response url="."/></transition>

    <transition-include name="createContent" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>
    <transition-include name="updateContent" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>
    <transition-include name="downloadContent" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>

    <!-- SV Fiscal transitions -->
    <transition name="upsertFiscalProfile">
        <service-call name="sv.localization.PartyFiscalServices.upsert#PartyFiscalProfile"/>
        <default-response url="."/>
    </transition>
    <transition name="storeSvAddress">
        <service-call name="sv.localization.PartyFiscalServices.store#SvPostalAddress"/>
        <default-response url="."/>
    </transition>
    <transition name="storeSvContact">
        <service-call name="sv.localization.PartyFiscalServices.store#SvDteContactInfo"/>
        <default-response url="."/>
    </transition>
    <transition name="getSvMunicipios">
        <service-call name="sv.localization.PartyFiscalServices.get#SvMunicipiosForDepartamento"
                      web-send-json-response="resultList"/>
        <default-response type="none"/>
    </transition>
    <transition name="getSvDistritos">
        <service-call name="sv.localization.PartyFiscalServices.get#SvDistritosForMunicipio"
                      web-send-json-response="resultList"/>
        <default-response type="none"/>
    </transition>

    <subscreens>
        <subscreens-item name="UpdateContactInfo" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty/UpdateContactInfo.xml"/>
        <subscreens-item name="ExpiredContactOther" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty/ExpiredContactOther.xml"/>
        <subscreens-item name="ExpiredPostal" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty/ExpiredPostal.xml"/>
        <subscreens-item name="UpdatePaymentMethodInfo" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty/UpdatePaymentMethodInfo.xml"/>
        <subscreens-item name="FindDuplicates" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty/FindDuplicates.xml"/>
    </subscreens>

    <actions>
        <entity-find-one entity-name="mantle.party.PartyDetail" value-field="party"/>
        <if condition="party == null"><return error="true" message="Proveedor no encontrado con ID ${partyId}"/></if>

        <entity-find-one entity-name="mantle.party.PartyRole" value-field="supplierRole">
            <field-map field-name="partyId"/><field-map field-name="roleTypeId" value="Supplier"/></entity-find-one>
        <if condition="supplierRole == null"><return error="true" message="Party ${partyId} no tiene rol Proveedor"/></if>

        <!-- SV Fiscal data -->
        <entity-find-one entity-name="sv.localization.party.SvFiscalProfile" value-field="svFiscalProfile">
            <field-map field-name="partyId"/>
        </entity-find-one>

        <entity-find-one entity-name="mantle.party.PartyIdentification" value-field="nitIdent">
            <field-map field-name="partyId"/><field-map field-name="partyIdTypeEnumId" value="PitNit"/>
        </entity-find-one>
        <entity-find-one entity-name="mantle.party.PartyIdentification" value-field="nrcIdent">
            <field-map field-name="partyId"/><field-map field-name="partyIdTypeEnumId" value="PitNrc"/>
        </entity-find-one>
        <set field="nitValue" from="nitIdent?.idValue"/>
        <set field="nrcValue" from="nrcIdent?.idValue ?: svFiscalProfile?.nrc"/>

        <!-- SV Address -->
        <entity-find entity-name="mantle.party.contact.PartyContactMechPostalAddress" list="postalList">
            <date-filter/><econdition field-name="partyId"/>
            <order-by field-name="-fromDate"/>
        </entity-find>
        <set field="primaryAddress" from="postalList?.first"/>

        <!-- Phone & Email -->
        <entity-find entity-name="mantle.party.contact.PartyContactMechTelecomNumber" list="phoneList">
            <date-filter/><econdition field-name="partyId"/>
            <order-by field-name="-fromDate"/>
        </entity-find>
        <set field="primaryPhone" from="phoneList?.first"/>
        <entity-find entity-name="mantle.party.contact.PartyContactMechInfo" list="emailList">
            <date-filter/><econdition field-name="partyId"/>
            <econdition field-name="contactMechTypeEnumId" value="CmtEmailAddress"/>
            <order-by field-name="-fromDate"/>
        </entity-find>
        <set field="primaryEmail" from="emailList?.first"/>

        <service-call name="sv.localization.PartyFiscalServices.check#DteReadiness"
                      in-map="[partyId:partyId]" out-map="dteCheck"/>
    </actions>

    <widgets>
        <!-- DTE Readiness Banner -->
        <container-box>
            <box-header title="Estado Fiscal"/>
            <box-body>
                <container-row><row-col lg="4">
                    <label text="CCF: " type="strong"/>
                    <label text="${dteCheck.readyForCcf ? 'Listo' : 'Incompleto'}"
                           style="${dteCheck.readyForCcf ? 'text-success' : 'text-danger'}"/>
                </row-col><row-col lg="4">
                    <label text="Tipo:" type="strong"/>
                    <label text=" ${party.partyTypeEnumId == 'PtyOrganization' ? 'Persona Jurídica' : 'Persona Natural'}"/>
                </row-col><row-col lg="4">
                    <link url="findOrder" text="Órdenes de compra" parameter-map="[vendorPartyId:partyId]"/>
                </row-col></container-row>
                <section name="DteIssuesSection" condition="dteCheck.issues"><widgets>
                    <section-iterate name="IssuesList" list="dteCheck.issues" entry="issue"><widgets>
                        <label text="- ${issue}" style="text-warning" type="div"/>
                    </widgets></section-iterate>
                </widgets></section>
            </box-body>
        </container-box>

        <container-row><row-col lg="6">
            <dynamic-dialog id="FindDuplicatesDialog" button-text="Buscar Duplicados" transition="FindDuplicates" width="960"/>
            <section-include name="HasDuplicatesSection" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>

            <section-include name="EditPartySection" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>

            <!-- SV Identification -->
            <container-box>
                <box-header title="Identificación Fiscal"/>
                <box-body>
                    <form-single name="SvFiscalProfileForm" transition="upsertFiscalProfile" map="svFiscalProfile">
                        <field name="partyId" from="partyId"><default-field><hidden/></default-field></field>

                        <field name="nit" from="nitValue"><default-field title="NIT">
                            <text-line size="22" input-type="text" maxlength="17"/>
                        </default-field></field>
                        <field name="nrc" from="nrcValue"><default-field title="NRC">
                            <text-line size="16" input-type="text" maxlength="8"/>
                        </default-field></field>

                        <field name="tipoContribuyenteEnumId"><default-field title="Tipo contribuyente">
                            <drop-down allow-empty="true"><entity-options key="${enumId}" text="${description}">
                                <entity-find entity-name="moqui.basic.Enumeration">
                                    <econdition field-name="enumTypeId" value="SvTipoContribuyente"/>
                                    <order-by field-name="sequenceNum"/>
                                </entity-find>
                            </entity-options></drop-down>
                        </default-field></field>

                        <field name="actividadEconomicaId"><default-field title="Actividad económica">
                            <drop-down allow-empty="true"><entity-options key="${actividadEconomicaId}" text="${mhCode} - ${description}">
                                <entity-find entity-name="sv.localization.party.SvEconomicActivity">
                                    <order-by field-name="mhCode"/>
                                </entity-find>
                            </entity-options></drop-down>
                        </default-field></field>

                        <field name="nombreComercial"><default-field title="Nombre comercial">
                            <text-line size="40"/>
                        </default-field></field>

                        <field name="submitButton"><default-field title="Guardar identificación"><submit/></default-field></field>

                        <field-layout>
                            <field-row><field-ref name="nit"/><field-ref name="nrc"/></field-row>
                            <field-row><field-ref name="tipoContribuyenteEnumId"/><field-ref name="actividadEconomicaId"/></field-row>
                            <field-ref name="nombreComercial"/>
                            <field-ref name="submitButton"/>
                        </field-layout>
                    </form-single>
                </box-body>
            </container-box>

            <section-include name="RolesSection" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>

        </row-col><row-col lg="6">

            <!-- SV Address -->
            <container-box>
                <box-header title="Dirección"/>
                <box-body>
                    <section name="CurrentAddressDisplay" condition="primaryAddress"><widgets>
                        <label text="${primaryAddress.complemento ?: primaryAddress.address1 ?: ''}" type="p"/>
                    </widgets></section>
                    <form-single name="SvAddressForm" transition="storeSvAddress">
                        <field name="partyId" from="partyId"><default-field><hidden/></default-field></field>
                        <field name="contactMechId" from="primaryAddress?.contactMechId"><default-field><hidden/></default-field></field>

                        <field name="departamentoGeoId" from="primaryAddress?.departamentoGeoId ?: primaryAddress?.stateProvinceGeoId">
                            <default-field title="Departamento">
                                <drop-down><entity-options key="${geoId}" text="${geoCodeAlpha2} - ${geoName}">
                                    <entity-find entity-name="moqui.basic.Geo">
                                        <econdition field-name="geoTypeEnumId" value="GEOT_STATE"/>
                                        <econdition field-name="geoId" operator="like" value="SV%"/>
                                        <order-by field-name="geoCodeAlpha2"/>
                                    </entity-find>
                                </entity-options></drop-down>
                            </default-field>
                        </field>

                        <field name="municipioGeoId" from="primaryAddress?.municipioGeoId">
                            <default-field title="Municipio">
                                <drop-down>
                                    <dynamic-options transition="getSvMunicipios" value-field="value" label-field="label">
                                        <depends-on field="departamentoGeoId"/>
                                    </dynamic-options>
                                </drop-down>
                            </default-field>
                        </field>

                        <field name="distritoGeoId" from="primaryAddress?.distritoGeoId">
                            <default-field title="Distrito">
                                <drop-down allow-empty="true">
                                    <dynamic-options transition="getSvDistritos" value-field="value" label-field="label">
                                        <depends-on field="municipioGeoId"/>
                                    </dynamic-options>
                                </drop-down>
                            </default-field>
                        </field>

                        <field name="complemento" from="primaryAddress?.complemento ?: primaryAddress?.address1">
                            <default-field title="Dirección completa">
                                <text-area rows="2" cols="50" maxlength="200"/>
                            </default-field>
                        </field>

                        <field name="submitAddress"><default-field title="Guardar dirección"><submit/></default-field></field>
                    </form-single>
                </box-body>
            </container-box>

            <!-- SV Contact -->
            <container-box>
                <box-header title="Contacto"/>
                <box-body>
                    <form-single name="SvContactForm" transition="storeSvContact">
                        <field name="partyId" from="partyId"><default-field><hidden/></default-field></field>
                        <field name="telefono" from="primaryPhone?.contactNumber">
                            <default-field title="Teléfono">
                                <text-line size="20" maxlength="30"/>
                            </default-field>
                        </field>
                        <field name="correo" from="primaryEmail?.infoString">
                            <default-field title="Correo electrónico">
                                <text-line size="40" maxlength="100"/>
                            </default-field>
                        </field>
                        <field name="submitContact"><default-field title="Guardar contacto"><submit/></default-field></field>
                    </form-single>
                </box-body>
            </container-box>

            <section-include name="NotesSection" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>
            <section-include name="PaymentMethodSection" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>
            <section-include name="FinancialAccountSection" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>
            <section-include name="ContentSection" location="component://SimpleScreens/screen/SimpleScreens/Party/EditParty.xml"/>

        </row-col></container-row>
    </widgets>
</screen>

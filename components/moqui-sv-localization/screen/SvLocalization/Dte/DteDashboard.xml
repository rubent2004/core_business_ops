<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Dashboard" default-menu-index="1">
    <actions>
        <entity-find-one entity-name="sv.localization.dte.SvDteSystemHealth" value-field="systemHealth">
            <field-map field-name="healthId" value="DEFAULT"/>
        </entity-find-one>
        <entity-find entity-name="sv.localization.dte.DteEmision" list="dteList" limit="50">
            <order-by field-name="-fechaGeneracion"/>
        </entity-find>
    </actions>
    <widgets>
        <container-box>
            <box-header title="Salud MH / resiliencia"/>
            <box-body>
                <form-single name="DteHealth" map="systemHealth" skip-form="true">
                    <field name="statusEnumId"><default-field title="Estado"><display-entity entity-name="moqui.basic.Enumeration"/></default-field></field>
                    <field name="consecutiveFailures"><default-field title="Fallos consecutivos"><display/></default-field></field>
                    <field name="lastCheckAt"><default-field title="Último check"><display/></default-field></field>
                    <field name="lastFailureMessage"><default-field title="Último fallo"><display/></default-field></field>
                    <field name="activeContingenciaId"><default-field title="Contingencia activa"><display/></default-field></field>
                </form-single>
            </box-body>
        </container-box>
        <container-box>
            <box-header title="Últimos DTE"/>
            <box-body>
                <container style="table-responsive">
                    <form-list name="DteList" list="dteList" skip-form="true">
                        <field name="dteEmisionId"><default-field title="DTE">
                            <link url="/apps/${appRoot}/SvLocalization/Dte/DteDetail?dteEmisionId=${dteEmisionId}"
                                  url-type="plain" text="${dteEmisionId}" link-type="anchor"/>
                        </default-field></field>
                        <field name="tipoDteCode"><default-field title="Tipo"><display/></default-field></field>
                        <field name="statusId"><default-field title="Estado"><display-entity entity-name="moqui.basic.StatusItem"/></default-field></field>
                        <field name="numeroControl"><default-field title="Número control"><display/></default-field></field>
                        <field name="codigoGeneracion"><default-field title="Código generación"><display/></default-field></field>
                        <field name="fechaGeneracion"><default-field title="Generado"><display/></default-field></field>
                    </form-list>
                </container>
            </box-body>
        </container-box>
    </widgets>
</screen>

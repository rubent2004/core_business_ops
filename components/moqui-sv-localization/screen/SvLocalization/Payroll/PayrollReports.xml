<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Reportes" default-menu-index="7">

    <transition name="exportIsssCsv" read-only="true">
        <actions>
            <service-call name="sv.localization.PayrollSvServices.export#IsssReport" in-map="context" out-map="csvResult"/>
            <script>
                ec.web.response.setHeader('Content-Disposition', "attachment; filename=\"${csvResult.filename}\"")
                ec.web.sendTextResponse(csvResult.csvText ?: '', csvResult.contentType ?: 'text/csv', null)
            </script>
        </actions>
        <default-response url="."/>
    </transition>

    <transition name="exportAfpCsv" read-only="true">
        <actions>
            <service-call name="sv.localization.PayrollSvServices.export#AfpReport" in-map="context" out-map="csvResult"/>
            <script>
                ec.web.response.setHeader('Content-Disposition', "attachment; filename=\"${csvResult.filename}\"")
                ec.web.sendTextResponse(csvResult.csvText ?: '', csvResult.contentType ?: 'text/csv', null)
            </script>
        </actions>
        <default-response url="."/>
    </transition>

    <transition name="exportRentaCsv" read-only="true">
        <actions>
            <service-call name="sv.localization.PayrollSvServices.export#RentaReport" in-map="context" out-map="csvResult"/>
            <script>
                ec.web.response.setHeader('Content-Disposition', "attachment; filename=\"${csvResult.filename}\"")
                ec.web.sendTextResponse(csvResult.csvText ?: '', csvResult.contentType ?: 'text/csv', null)
            </script>
        </actions>
        <default-response url="."/>
    </transition>

    <actions>
        <set field="svPayrollRunId" from="svPayrollRunId"/>
        <set field="run" from="null"/>
        <set field="lineList" from="[]"/>
        <set field="org" from="null"/>
        <if condition="svPayrollRunId">
            <entity-find-one entity-name="sv.localization.payroll.SvPayrollRun" value-field="run"/>
            <if condition="run != null">
                <entity-find entity-name="sv.localization.payroll.SvPayrollRunEmployee" list="lineList">
                    <econdition field-name="svPayrollRunId" from="svPayrollRunId"/>
                    <order-by field-name="employeePartyId"/>
                </entity-find>
                <entity-find-one entity-name="mantle.party.Organization" value-field="org">
                    <field-map field-name="partyId" from="run.organizationPartyId"/>
                </entity-find-one>
            </if>
        </if>
    </actions>

    <widgets>
        <container-box>
            <box-header title="Reportes de Nómina"/>
            <box-body>
                <label text="Boletas de pago en PDF y exportes CSV de planillas ISSS, AFP y renta retenida para una corrida.
                    Los CSV son insumos operativos; no sustituyen los formatos oficiales certificados por ISSS / SSF / Ministerio de Hacienda." type="p"/>
                <form-single name="SelectRun" transition=".">
                    <field name="svPayrollRunId"><default-field title="Corrida">
                        <drop-down allow-empty="true">
                            <entity-options key="${svPayrollRunId}" text="${svPayrollRunId} — ${periodYearMonth} — ${statusId}">
                                <entity-find entity-name="sv.localization.payroll.SvPayrollRun">
                                    <order-by field-name="-runDate"/>
                                </entity-find>
                            </entity-options>
                        </drop-down>
                    </default-field></field>
                    <field name="submitButton"><default-field title="Cargar"><submit/></default-field></field>
                </form-single>
            </box-body>
        </container-box>

        <section name="RunDetail" condition="run != null"><widgets>
            <container-box>
                <box-header title="Corrida ${run.svPayrollRunId} — ${run.periodYearMonth}"/>
                <box-body>
                    <container-row>
                        <row-col lg="4">
                            <label text="Organización: " type="strong"/>
                            <label text="${org?.organizationName ?: run.organizationPartyId}"/>
                        </row-col>
                        <row-col lg="2">
                            <label text="Estado: " type="strong"/>
                            <display-entity entity-name="moqui.basic.StatusItem"
                                    key-map="[statusId:run.statusId]" text="${description}"/>
                        </row-col>
                        <row-col lg="3">
                            <label text="Empleados: " type="strong"/>
                            <label text="${run.employeeCount ?: 0}"/>
                        </row-col>
                        <row-col lg="3">
                            <label text="Total bruto: " type="strong"/>
                            <label text="${ec.l10n.format(run.totalGross ?: 0, '$ #,##0.00')}"/>
                        </row-col>
                    </container-row>
                </box-body>
            </container-box>

            <container-box>
                <box-header title="Exportar planillas legales"/>
                <box-body>
                    <container>
                        <link url="exportIsssCsv" text="Planilla ISSS (CSV)" link-type="anchor-button" btn-type="info">
                            <parameter name="svPayrollRunId"/>
                        </link>
                        <label text=" " type="span"/>
                        <link url="exportAfpCsv" text="Planilla AFP (CSV)" link-type="anchor-button" btn-type="info">
                            <parameter name="svPayrollRunId"/>
                        </link>
                        <label text=" " type="span"/>
                        <link url="exportRentaCsv" text="Renta retenida (CSV)" link-type="anchor-button" btn-type="info">
                            <parameter name="svPayrollRunId"/>
                        </link>
                    </container>
                </box-body>
            </container-box>

            <container-box>
                <box-header title="Boletas de pago por empleado (${lineList.size()})"/>
                <box-body-nopad>
                    <container style="table-responsive">
                        <form-list name="SlipList" list="lineList" skip-form="true">
                            <row-actions>
                                <entity-find-one entity-name="mantle.party.Person" value-field="person">
                                    <field-map field-name="partyId" from="employeePartyId"/>
                                </entity-find-one>
                                <set field="empName" from="[person?.firstName, person?.lastName].findAll { it }.join(' ') ?: employeePartyId"/>
                                <set field="canPrint" from="statusId != 'SvPayLineSkipped'"/>
                            </row-actions>
                            <field name="employeePartyId">
                                <header-field title="Empleado"/>
                                <default-field><display text="${empName}"/></default-field>
                            </field>
                            <field name="statusId">
                                <header-field title="Estado"/>
                                <default-field>
                                    <display-entity entity-name="moqui.basic.StatusItem" text="${description}"/>
                                </default-field>
                            </field>
                            <field name="grossMonthlyAmount">
                                <header-field title="Bruto"/>
                                <default-field><display format="$ #,##0.00"/></default-field>
                            </field>
                            <field name="netPay">
                                <header-field title="Neto"/>
                                <default-field><display format="$ #,##0.00" style="text-success"/></default-field>
                            </field>
                            <field name="boletaPdf">
                                <header-field title="Boleta"/>
                                <default-field>
                                    <section name="PrintLink" condition="canPrint"><widgets>
                                        <link url="/fop/apps/SvLocalization/Payroll/PrintPayrollSlip"
                                              text="PDF" link-type="anchor-button" target-window="_blank">
                                            <parameter name="svPayrollRunId"/>
                                            <parameter name="employeePartyId"/>
                                        </link>
                                    </widgets></section>
                                    <section name="NoPrintLink" condition="!canPrint"><widgets>
                                        <label text="—"/>
                                    </widgets></section>
                                </default-field>
                            </field>
                            <field name="skipReason">
                                <header-field title="Observaciones"/>
                                <default-field><display/></default-field>
                            </field>
                        </form-list>
                    </container>
                </box-body-nopad>
            </container-box>
        </widgets></section>
    </widgets>
</screen>

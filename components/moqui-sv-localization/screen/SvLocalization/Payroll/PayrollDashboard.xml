<?xml version="1.0" encoding="UTF-8"?>
<screen xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://moqui.org/xsd/xml-screen-3.xsd"
        default-menu-title="Dashboard" default-menu-index="1">
    <actions>
        <entity-find entity-name="sv.localization.payroll.SvPayrollScheme" list="payrollSchemeList">
            <order-by field-name="schemeTypeEnumId"/>
            <order-by field-name="-fromDate"/>
        </entity-find>
        <entity-find entity-name="sv.localization.payroll.SvMinimumWageSector" list="minimumWageList">
            <order-by field-name="sectorEnumId"/>
            <order-by field-name="-fromDate"/>
        </entity-find>
        <service-call name="sv.localization.PayrollSvServices.calculate#MonthlyPayroll"
                in-map="[grossMonthlyAmount:'700.00', includeEmployerContributions:true, currencyUomId:'USD']"
                out-map="payrollExample"/>
    </actions>

    <widgets>
        <container>
            <link url="PayrollSchemes" text="Reglas nómina" link-type="anchor-button"/>
            <link url="MinimumWageSectors" text="Salarios mínimos" link-type="anchor-button"/>
            <link url="PayrollPreview" text="Preview nómina" link-type="anchor-button"/>
            <link url="BenefitsPreview" text="Vacación y aguinaldo" link-type="anchor-button"/>
        </container>

        <container-row>
            <row-col lg="6">
                <container-box>
                    <box-header title="Ejemplo operativo"/>
                    <box-body>
                        <label text="Salario bruto mensual: USD 700.00" type="p"/>
                        <form-single name="PayrollExample" map="payrollExample" skip-form="true">
                            <field name="isssEmployee"><default-field title="ISSS empleado"><display/></default-field></field>
                            <field name="afpEmployee"><default-field title="AFP empleado"><display/></default-field></field>
                            <field name="rentaMonthly"><default-field title="Renta mensual"><display/></default-field></field>
                            <field name="netPay"><default-field title="Neto esperado"><display/></default-field></field>
                            <field name="employerCost"><default-field title="Costo patronal"><display/></default-field></field>
                        </form-single>
                    </box-body>
                </container-box>
            </row-col>
            <row-col lg="6">
                <container-box>
                    <box-header title="Alcance Fase 4B"/>
                    <box-body>
                        <label text="Pantallas de consulta, mantenimiento versionado y preview. No genera facturas, pagos ni asientos." type="p"/>
                        <label text="Los cálculos se ejecutan por servicios PayrollSvServices y las reglas vienen de datos versionados." type="p"/>
                    </box-body>
                </container-box>
            </row-col>
        </container-row>

        <container-box>
            <box-header title="Reglas vigentes e históricas"/>
            <box-body>
                <form-list name="PayrollSchemeList" list="payrollSchemeList" skip-form="true">
                    <field name="schemeTypeEnumId"><default-field title="Tipo"><display-entity entity-name="moqui.basic.Enumeration"/></default-field></field>
                    <field name="svPayrollSchemeId"><default-field title="Esquema"><display/></default-field></field>
                    <field name="description"><default-field title="Descripción"><display/></default-field></field>
                    <field name="fromDate"><default-field title="Desde"><display/></default-field></field>
                    <field name="thruDate"><default-field title="Hasta"><display/></default-field></field>
                    <field name="currencyUomId"><default-field title="Moneda"><display/></default-field></field>
                </form-list>
            </box-body>
        </container-box>

        <container-box>
            <box-header title="Salarios mínimos"/>
            <box-body>
                <form-list name="MinimumWageList" list="minimumWageList" skip-form="true">
                    <field name="sectorEnumId"><default-field title="Sector"><display-entity entity-name="moqui.basic.Enumeration"/></default-field></field>
                    <field name="description"><default-field title="Descripción"><display/></default-field></field>
                    <field name="monthlyAmount"><default-field title="Mensual"><display/></default-field></field>
                    <field name="dailyAmount"><default-field title="Diario"><display/></default-field></field>
                    <field name="fromDate"><default-field title="Desde"><display/></default-field></field>
                    <field name="thruDate"><default-field title="Hasta"><display/></default-field></field>
                </form-list>
            </box-body>
        </container-box>
    </widgets>
</screen>
